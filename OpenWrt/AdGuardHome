
config AdGuardHome 'AdGuardHome'
	option enabled '1'
	option httpport '2000'
	option redirect 'dnsmasq-upstream'
	option configpath '/etc/AdGuardHome.yaml'
	option workdir '/tmp/AdGuardHome'
